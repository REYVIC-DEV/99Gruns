{% comment %}
  Renders an arrow icon (left or right)

  Accepts:
  - direction: 'left' or 'right' (default: 'right')
  - color: hex color value (default: currentColor)
  - size: size in pixels (default: 24)
{% endcomment %}

{%- assign icon_color = color | default: 'currentColor' -%}
{%- assign icon_size = size | default: 24 -%}

{%- if direction == 'left' -%}
  <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="{{ icon_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-arrow-left" style="fill: none;width: 100%;height: auto" role="presentation"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
{%- else -%}
  <svg xmlns="http://www.w3.org/2000/svg" width="{{ icon_size }}" height="{{ icon_size }}" viewBox="0 0 24 24" fill="none" stroke="{{ icon_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-arrow-right" style="fill: none;width: 100%;height: auto" role="presentation"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
{%- endif -%}
