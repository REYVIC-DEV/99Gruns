{% comment %}
  Icon Check Snippet

  This snippet renders a check icon with customizable color and size.

  Usage:
    Basic: {% render 'icon-check' %}
    With custom color and size: {% render 'icon-check', color: '#FF0000', size: '30px' %}

  Parameters:
    color (string): Hex color for the icon, defaults to '#007E40'
    size (string): Size for the icon (width x height), defaults to '25px'
{% endcomment %}

{% assign color = color | default: '#007E40' %}
{% assign size = size | default: '25px' %}

<svg stroke="{{ color }}" fill="{{ color }}" stroke-width="0" viewBox="0 0 16 16" role="presentation" style="width:{{ size }};height:{{ size }};max-height:100%" xmlns="http://www.w3.org/2000/svg">
  <path d="M10.97 4.97a.75.75 0 0 1 1.07 1.05l-3.99 4.99a.75.75 0 0 1-1.08.02L4.324 8.384a.75.75 0 1 1 1.06-1.06l2.094 2.093 3.473-4.425z"></path>
</svg>
