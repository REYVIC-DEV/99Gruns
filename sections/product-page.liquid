                            <strong class="tw-text-[18px]" id="plan-price-{{ forloop.index }}">
                              $50
                            </strong>
                            <s class="tw-text-[16px]" id="plan-original-price-{{ forloop.index }}">
                              $99
                            </s>
                          </span>
                          <p class="!tw-m-0 tw-font-bold tw-text-[14px]" id="per-day-{{ forloop.index }}">$perday</p>
                          <div class="tw-h-[32px] tw-px-[5%] tw-py-[4px] tw-absolute tw-top-3 tw-right-3 tw-rounded-full" style="background:{{ section.settings.sale_percentage_badge_bg_color }}">
