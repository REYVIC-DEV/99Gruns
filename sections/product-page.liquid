              >
                <span>Start Now</span>
                <div class="loading__spinner tw-absolute tw-inset-0 tw-hidden tw-flex tw-items-center tw-justify-center">
                  {%- render 'loading-spinner' -%}
                </div>
              </button>
              {% if section.settings.show_discount_text %}
                <style>
                  .discount-text * {
                    color: inherit !important;
                    margin: 0 !important;
                    font-size: inherit !important;
                  }
                </style>
                <div class="discount-text tw-font-dm-sans tw-text-[14px] tw-flex tw-justify-center tw-leading-[160%] tw-tracking-tighter" style="background-color: {{ section.settings.discount_text_bg_color }}; color: {{ section.settings.discount_text_color }}">
