                <span>{%- render 'icon-x-simple' -%}</span>
                <p class="tw-text-[13px]">No Free Shipping</p>
              </div>
              <button
                type="submit"
                class="
                  tw-inline-flex
                  tw-items-center
                  tw-justify-center
                  tw-font-bold
                  tw-px-12
                  tw-py-3
                  tw-rounded-full
                  tw-no-underline
      
                tw-bg-[#007e40]
                hover:tw-bg-[#00582d]
                    tw-text-white
      
                  hover:tw-shadow-[0_0_0_0.5px_#000,2px_2px_0_#000]
                  hover:tw-translate-x-1
                  hover:tw-translate-y-1
                  tw-shadow-[inset_0_0_0_0.5px_#000,4px_4px_0_#000]
      
      
                  tw-transition-all
                  tw-duration-300
                  tw-ease-out
      
                  tw-h-[46px]
                  tw-w-full
      
                  tw-text-[16px]
      
                  tw-leading-[120%]
                  tw-tracking-tighter
      
                  tw-flex-nowrap
                  tw-text-nowrap
                  tw-cursor-pointer
                  tw-relative
                "
                style="border: 1px solid black"
              >
                <span>Try Now</span>
                <div class="loading__spinner tw-absolute tw-inset-0 tw-hidden tw-flex tw-items-center tw-justify-center">
                  {%- render 'loading-spinner' -%}
