<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-slider.js' | asset_url }}" defer="defer"></script>

<script type="application/json" id="product-variants">
  {{ section.settings.selected-product.variants | json }}
</script>
<script>
document.addEventListener('DOMContentLoaded', function () {
  const form = document.querySelector('product-form form');
  if (!form) return;

  const variants = JSON.parse(
    document.getElementById('product-variants').textContent
  );

  const dietInputs = form.querySelectorAll(
    'input[type="radio"][name^="options["]'
  );

  const sellingPlanInputs = form.querySelectorAll(
    'input[name="selling_plan"]'
  );

  const variantInput = form.querySelector('input[name="id"]');

  // Global variables for one-time purchase elements
  const lowSugarOneTime = document.querySelector(
    '#one_time_purchase_low-sugar-one-time'
  );

  const sugarFreeOneTime = document.querySelector(
    '#one_time_purchase_sugar-free-one-time'
  );

  // Add click event listeners
  if (lowSugarOneTime) {
    lowSugarOneTime.addEventListener('click', function() {
      const hiddenPurchase = this.querySelector('.hidden_purchase');
      if (hiddenPurchase) {
        hiddenPurchase.classList.toggle('tw-hidden');
      }
    });
    
    // Prevent toggle when clicking the button inside
    const lowSugarButton = lowSugarOneTime.querySelector('.hidden_purchase button');
    if (lowSugarButton) {
      lowSugarButton.addEventListener('click', function(e) {
        e.stopPropagation();
      });
    }
  }

  if (sugarFreeOneTime) {
    sugarFreeOneTime.addEventListener('click', function() {
      const hiddenPurchase = this.querySelector('.hidden_purchase');
      if (hiddenPurchase) {
        hiddenPurchase.classList.toggle('tw-hidden');
      }
    });
    
    // Prevent toggle when clicking the button inside
    const sugarFreeButton = sugarFreeOneTime.querySelector('.hidden_purchase button');
    if (sugarFreeButton) {
      sugarFreeButton.addEventListener('click', function(e) {
        e.stopPropagation();
      });
    }
  }

  /* --------------------------------------------
   * Swiper DOM references
   * ------------------------------------------ */
  const mainWrapper = document.querySelector('.product-slider .swiper-wrapper');
  const thumbWrapper = document.querySelector('.product-thumb .swiper-wrapper');

  if (!mainWrapper || !thumbWrapper) return;

  // Store original slides ONCE
  const originalMainSlides = Array.from(mainWrapper.children);
  const originalThumbSlides = Array.from(thumbWrapper.children);

  // selling_plan_id -> variant_id
  let sellingPlanVariantMap = {};

  /* --------------------------------------------
   * Utilities
   * ------------------------------------------ */
  function formatMoney(cents) {
    return `$${(cents / 100).toFixed(2)}`;
  }

  function getDiscountPercent(originalPrice, salePrice) {
    if (
      !originalPrice ||
      originalPrice <= 0 ||
      !salePrice ||
      salePrice >= originalPrice
    ) {
      return 0;
    }

    return Math.round(
      ((originalPrice - salePrice) / originalPrice) * 100
    );
  }

  /* --------------------------------------------
   * Rebuild sliders by diet (CORE FIX)
   * ------------------------------------------ */
  function rebuildSlidersByDiet(dietValue) {
  // Destroy existing Swipers
  if (window.productSliders?.main_swiper) {
    window.productSliders.main_swiper.destroy(true, true);
    window.productSliders.main_swiper = null;
  }

  if (window.productSliders?.thumb_swiper) {
    window.productSliders.thumb_swiper.destroy(true, true);
    window.productSliders.thumb_swiper = null;
  }

  // Clear DOM
  mainWrapper.innerHTML = '';
  thumbWrapper.innerHTML = '';

  // Filter logic:
  // - include images matching the diet
  // - include "General" images
  const filteredMainSlides = originalMainSlides.filter(slide => {
    const img = slide.querySelector('img');
    if (!img) return false;

    return (
      img.alt === dietValue ||
      img.alt === 'General'
    );
  });

  const filteredThumbSlides = originalThumbSlides.filter(slide => {
    const img = slide.querySelector('img');
    if (!img) return false;

    return (
      img.alt === dietValue ||
      img.alt === 'General'
    );
  });

  // Append slides
  filteredMainSlides.forEach(slide => mainWrapper.appendChild(slide));
  filteredThumbSlides.forEach(slide => thumbWrapper.appendChild(slide));

  // Re-init Swiper
  initProductSliders();
}


  /* --------------------------------------------
   * Diet → Selling plans + sliders
   * ------------------------------------------ */
  function handleDietChange(dietValue) {
    console.log('🔄 handleDietChange called with dietValue:', dietValue);

    if (!dietValue) {
      console.log('❌ No dietValue provided, returning');
      return;
    }

    if (lowSugarOneTime) lowSugarOneTime.classList.add('tw-hidden');
    if (sugarFreeOneTime) sugarFreeOneTime.classList.add('tw-hidden');
    if (dietValue === 'Low Sugar') {
      if (lowSugarOneTime) lowSugarOneTime.classList.remove('tw-hidden');
      console.log('✅ Showing Low Sugar one-time purchase');
    } else if (dietValue === 'Sugar Free') {
      if (sugarFreeOneTime) sugarFreeOneTime.classList.remove('tw-hidden');
      console.log('✅ Showing Sugar Free one-time purchase');
    }

    // Rebuild sliders FIRST
    rebuildSlidersByDiet(dietValue);

    // Filter variants by diet
    const filteredVariants = variants.filter(
      variant => variant.option1 === dietValue
    );
    console.log('📊 Filtered variants for diet:', dietValue, filteredVariants);

    // Get all selling plan inputs (dynamic count)
    const sellingPlanInputs = form.querySelectorAll('input[name="selling_plan"]');
    console.log('🎯 Found selling plan inputs:', sellingPlanInputs.length, Array.from(sellingPlanInputs).map(input => ({ id: input.id, index: input.dataset.planIndex })));

    if (filteredVariants.length < sellingPlanInputs.length) {
      console.warn('⚠️ Not enough variants for available selling plans:', {
        dietValue,
        availableVariants: filteredVariants.length,
        neededPlans: sellingPlanInputs.length
      });
      return;
    }

    // Build selling plan → variant map
    sellingPlanVariantMap = {};
    console.log('🗺️ Building plan-to-variant mapping...');

    // Update each selling plan input with corresponding variant data
    sellingPlanInputs.forEach((input, index) => {
      const variant = filteredVariants[index];
      console.log(`🔗 Processing Plan ${index} (${input.id}):`, {
        variantTitle: variant?.title,
        variantId: variant?.id,
        hasSellingPlanAllocations: variant?.selling_plan_allocations?.length > 0
      });

      if (!variant?.selling_plan_allocations?.length) {
        console.warn(`❌ Missing selling plan allocation for variant ${index}:`, variant);
        return;
      }

      // Assign selling plan ID
      const sellingPlanId = variant.selling_plan_allocations[0].selling_plan_id;
      input.value = sellingPlanId;
      console.log(`✅ Set selling plan ID for Plan ${index}:`, sellingPlanId);

      // Map selling plan to variant
      sellingPlanVariantMap[sellingPlanId] = variant.id;
      console.log(`🗺️ Mapped selling plan ${sellingPlanId} to variant ${variant.id}`);

      // Update prices for this plan
      const planIndex = input.dataset.planIndex;
      const newPrice = formatMoney(variant.selling_plan_allocations[0].price);
      const originalPrice = formatMoney(variant.price);
      const perDayPrice = formatMoney(variant.selling_plan_allocations[0].unit_price);
      const discountPercent = getDiscountPercent(
        variant.selling_plan_allocations[0].compare_at_price,
        variant.selling_plan_allocations[0].price
      );

      console.log(`💰 Updating prices for Plan ${planIndex}:`, {
        price: newPrice,
        originalPrice,
        perDayPrice,
        discountPercent: discountPercent + '% off'
      });

      // Only update elements if they exist (not hidden in kids mode)
      const priceElement = document.querySelector(`#plan-price-${planIndex}`);
      const originalPriceElement = document.querySelector(`#plan-original-price-${planIndex}`);
      const perDayElement = document.querySelector(`#per-day-${planIndex}`);
      const percentElement = document.querySelector(`#selling_plan_percent_${planIndex}`);

      if (priceElement) priceElement.textContent = newPrice;
      if (originalPriceElement) originalPriceElement.textContent = originalPrice;
      if (perDayElement) perDayElement.textContent = perDayPrice;
      if (percentElement) percentElement.textContent = discountPercent + '% off';
    });

    console.log('🗺️ Final selling plan mapping:', sellingPlanVariantMap);

    // Preserve current selection or default to first if none selected
    const currentlySelected = form.querySelector('input[name="selling_plan"]:checked');
    console.log('🎯 Current selection:', currentlySelected ? currentlySelected.id : 'none');

    if (!currentlySelected && sellingPlanInputs.length > 0) {
      console.log('🎯 No selection, defaulting to first plan');
      sellingPlanInputs[0].checked = true;
      variantInput.value = sellingPlanVariantMap[sellingPlanInputs[0].value];
      updateSubscriptionText(sellingPlanInputs[0].id);
      console.log('✅ Set default selection to:', sellingPlanInputs[0].id);
    } else if (currentlySelected) {
      console.log('🎯 Preserving existing selection:', currentlySelected.id);
      // Update variant ID for the currently selected plan
      variantInput.value = sellingPlanVariantMap[currentlySelected.value];
      updateSubscriptionText(currentlySelected.id);
      console.log('✅ Updated variant ID to:', sellingPlanVariantMap[currentlySelected.value]);
    }
  }

  /* --------------------------------------------
   * Selling plan → Variant mapping
   * ------------------------------------------ */
  sellingPlanInputs.forEach((input, index) => {
    input.addEventListener('change', () => {
      if (!input.checked) return;

      const variantId = sellingPlanVariantMap[input.value];
      if (!variantId) return;

      variantInput.value = variantId;

      // Update quantity based on plan index (1-based)
      const quantityInput = form.querySelector('input[name="quantity"]');
      if (quantityInput) {
        quantityInput.value = index + 1;
        console.log(`📦 Updated quantity to ${index + 1} for plan ${index} (${input.id})`);
      }

      // Update subscription text based on selection
      updateSubscriptionText(input.id);
    });
  });

  // Function to update subscription text
  function updateSubscriptionText(selectedPlanId) {
    const subscriptionTextElements = document.querySelectorAll('.tw-flex.tw-flex-col > div.tw-h-\\[25px\\] p');
    if (subscriptionTextElements.length > 0 && selectedPlanId) {
      // Get the selected plan input and its gummies per month
      const selectedInput = document.getElementById(selectedPlanId);
      if (selectedInput) {
        const gummiesPerMonth = selectedInput.dataset.gummiesPerMonth;
        const packsPerMonth = Math.ceil(gummiesPerMonth / 28); // Assuming 28 gummies per pack

        subscriptionTextElements[0].textContent = `${packsPerMonth} packs every 4 weeks (${gummiesPerMonth} gummies)`;
      }
    }
  }

  /* --------------------------------------------
   * Diet bindings
   * ------------------------------------------ */
  dietInputs.forEach(input => {
    input.addEventListener('change', () => {
      if (input.checked) {
        handleDietChange(input.value);
      }
    });
  });

  /* --------------------------------------------
   * Init on page load
   * ------------------------------------------ */
  dietInputs.forEach(input => {
    if (input.checked) {
      handleDietChange(input.value);
    }
  });
  
  // Set initial subscription text based on default selection
  const defaultSelectedPlan = form.querySelector('input[name="selling_plan"]:checked');
  if (defaultSelectedPlan) {
    updateSubscriptionText(defaultSelectedPlan.id);
  }
});

// Modal trigger
document.addEventListener('click', function(e) {
  const button = e.target.closest('#view-nutrition-label-btn');
  if (button) {
    // Get image URLs from data attributes
    const lowSugarImage = button.dataset.lowSugarImage;
    const sugarFreeImage = button.dataset.sugarFreeImage;

    // Create and show modal
    const modalHTML = `
      <section class="modal-overlay tw-flex tw-justify-center tw-py-[50px] tw-bg-[#000000]/[60%] tw-fixed tw-top-0 tw-left-0 tw-w-full tw-h-full tw-z-50">
        <div class="tw-overflow-y-scroll tw-max-w-[85%] tw-min-w-[85%] tw-w-full tw-bg-white tw-flex tw-flex-col tw-items-center tw-relative">
          <button class="modal-close tw-absolute tw-top-4 tw-right-4 tw-w-8 tw-h-8 tw-rounded-full tw-bg-gray-200 hover:tw-bg-gray-300 tw-flex tw-items-center tw-justify-center tw-transition-colors tw-duration-200 tw-z-10">
            <span class="tw-text-black tw-text-xl tw-font-bold">×</span>
          </button>
          <div class="tw-w-[90%] tw-py-[24px] tw-px-[20px] tw-flex tw-flex-col">
            <div class="tw-flex tw-w-full tw-border tw-border-black tw-border-solid tw-rounded-xl">
              <div class="modal-tab tw-w-[50%] tw-text-center tw-border-r tw-border-r-black tw-border tw-border-solid tw-border-y-0 tw-border-l-0 tw-cursor-pointer tw-transition-colors tw-duration-200 active-tab" data-tab="low-sugar">
                <h2 class="!tw-m-0 tw-text-[16px] tw-font-bold">Low Sugar</h2>
              </div>
              <div class="modal-tab tw-w-[50%] tw-text-center tw-border-l tw-border-l-black tw-border tw-border-solid tw-border-y-0 tw-border-r-0 tw-cursor-pointer tw-transition-colors tw-duration-200" data-tab="sugar-free">
                <h2 class="!tw-m-0 tw-text-[16px] tw-font-bold">Sugar-Free</h2>
              </div>
            </div>
            <div class="tab-content active" data-tab-content="low-sugar">
              <img src="${lowSugarImage}" alt="Low Sugar Nutrition Label" width="100%" height="auto">
            </div>
            <div class="tab-content tw-hidden" data-tab-content="sugar-free">
              <img src="${sugarFreeImage}" alt="Sugar Free Nutrition Label" width="100%" height="auto">
            </div>
          </div>
        </div>
      </section>
    `;

    // Append modal to body
    document.body.insertAdjacentHTML('beforeend', modalHTML);

    // Initialize modal functionality (tabs and close)
    initializeModal();
  }
});

function initializeModal() {
  (function() {
    // Prevent multiple bindings
    if (window.modalTabsInitialized) return;
    window.modalTabsInitialized = true;

    // Close modal function
    function closeModal(clickedElement) {
      // If a specific element was clicked, find its modal parent
      if (clickedElement) {
        const modal = clickedElement.closest('.modal-overlay');
        if (modal) {
          modal.remove();
          return;
        }
      }

      // Fallback: remove all modals
      const modals = document.querySelectorAll('.modal-overlay');
      modals.forEach(modal => {
        modal.remove();
      });
    }

    document.addEventListener('click', function(e) {
      // Handle modal close button
      if (e.target.closest('.modal-close')) {
        closeModal();
        return;
      }

      // Handle tab clicks
      if (e.target.closest('.modal-tab')) {
        const tab = e.target.closest('.modal-tab');
        const tabName = tab.dataset.tab;

        // Remove active class from all tabs
        document.querySelectorAll('.modal-tab').forEach(t => {
          t.classList.remove('active-tab');
          t.classList.remove('tw-bg-[#007e40]');
          t.classList.add('tw-text-black');
        });

        // Add active class to clicked tab
        tab.classList.add('active-tab');
        tab.classList.add('tw-bg-[#007e40]');
        tab.classList.add('tw-text-white');

        // Hide all tab contents
        document.querySelectorAll('.tab-content').forEach(content => {
          content.classList.add('tw-hidden');
          content.classList.remove('active');
        });

        // Show selected tab content
        const activeContent = document.querySelector(`[data-tab-content="${tabName}"]`);
        if (activeContent) {
          activeContent.classList.remove('tw-hidden');
          activeContent.classList.add('active');
        }
      }
    });

    // Close modal when clicking on overlay (outside modal content)
    document.addEventListener('click', function(e) {
      if (e.target.classList.contains('modal-overlay')) {
        closeModal();
      }
    });

    // Close modal with Escape key
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeModal();
      }
    });

    // Set initial active tab
    const firstTab = document.querySelector('.modal-tab');
    if (firstTab) {
      firstTab.classList.add('active-tab');
      firstTab.classList.add('tw-bg-[#007e40]');
      firstTab.classList.add('tw-text-white');
    }
  })();
}
</script>


