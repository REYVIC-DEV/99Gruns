{% assign title_color = nil %}
{% assign description_color = nil %}
{% assign badge_text_color = nil %}
{% assign sale_percentage_bg_color = section.settings.sale_percentage_badge_bg_color %}
{% for block in section.blocks %}
  {% case block.type %}
    {% when 'section_title' %}
      {% assign title_color = block.settings.title_color %}
    {% when 'section_description' %}
      {% assign description_color = block.settings.description_color %}
    {% when 'section_top_badge' %}
      {% assign badge_text_color = block.settings.badge_text_color %}
  {% endcase %}
{% endfor %}
<style>
  #product-page-section-{{ section.id }} {
    --section-title-color: {{ title_color }};
    --section-description-color: {{ description_color }};
    --section-badge-text-color: {{ badge_text_color }};
    --sale-percentage-bg-color: {{ sale_percentage_bg_color }};
  }
  .option-pill input:checked+span {
    background-color: {{ section.settings.diet_picker_active_bg | default:"#0a7a3c" }} !important;
}
</style>
{{ 'product-page.css' | asset_url | stylesheet_tag }}
<section id="product-page-section-{{ section.id }}" class="tw-w-full">

  <div class="page-width tw-p-[15px] tw-flex tw-flex-col tw-items-center tw-justify-center tw-w-full tw-gap-[24px] md:tw-p-[5%]">
    <div class="tw-flex tw-flex-col tw-items-center tw-justify-center tw-gap-[5px] tw-text-center">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
        {% when 'section_top_badge' %}
            <div class="tw-flex tw-items-center tw-self-center tw-justify-center tw-mt-[15px] tw-rounded-full tw-bg-lt-yellow !tw-w-[148px] md:!tw-w-[211px] xl:!tw-w-[190px] tw-py-[8px] tw-px-[20px] tw-line-clamp-1 tw-tracking-tighter">
              <strong class="tw-text-[12px] section-top-badge"> {{ block.settings.badge_text }} </strong>
            </div>
          {%- when 'star_reviews' -%}
            <div class="">
              {% render 'home-star-review',
                rating: block.settings.star_rating,
                star_color: block.settings.star_color,
                review_text_mobile: block.settings.review_text_mobile,
                review_text_desktop: block.settings.review_text_desktop,
                font_color: block.settings.review_font_color,
                strong_font_color: block.settings.strong_font_color
              %}
            </div>
          {%- when 'section_title' -%}
            <div class="tw-w-full">
              <div class="section-title !tw-m-0 !tw-text-[32px]">
                {{ block.settings.section_title }}
              </div>
            </div>
          {% when 'section_description' %}
            <span class="section-description">
              <p class="!tw-m-0 ">
                {{ block.settings.section_description }}
              </p>
            </span>
        {%- endcase -%}
      {%- endfor -%}
    </div>
    <div class="tw-flex tw-flex-col xl:tw-flex-row xl:tw-gap-[32px] tw-w-full tw-max-w-[450px] lg:!tw-max-w-full tw-items-center xl:tw-items-start tw-justify-center">
      {% comment %} product slider here {% endcomment %}
      <div class="tw-w-full tw-flex tw-flex-col tw-gap-[10px] lg:tw-w-full tw-max-w-[450px]">
        <!-- Slider main container -->
        <div class="swiper product-slider tw-w-full">
          <!-- Additional required wrapper -->
          <div class="swiper-wrapper !tw-w-full tw-max-w-[376px] md:tw-max-w-[676px] lg:tw-max-w-[906px] xl:tw-max-w-[445px]">
            <!-- Slides -->
            {% for image in section.settings.selected-product.images %}
              <div class="swiper-slide tw-flex tw-items-center tw-justify-center">
                <img
                  src="{{ image.src | image_url: width: 906, height: 906 }}"
                  width="906"
                  height="906"
                  class="!tw-w-full  tw-max-w-[376px] md:tw-max-w-[676px] lg:tw-max-w-[906px] xl:tw-max-w-[445px] tw-h-fit tw-rounded-[10px] tw-object-contain tw-border tw-border-black tw-border-solid"
                  alt="{{ image.alt }}"
                >
              </div>
            {% endfor %}
          </div>
        </div>

        <!-- Slider main container -->
        <div class="swiper product-thumb tw-w-full">
          <!-- Additional required wrapper -->
          <div class="swiper-wrapper tw-w-[43px] tw-h-[43px] tw-rounded-[20px]">
            <!-- Slides -->
            {% for image in section.settings.selected-product.images %}
              <div class="swiper-slide tw-flex tw-items-center tw-justify-center tw-w-[43px] tw-h-[43px] tw-rounded-[3px] tw-overflow-hidden">
                <img
                  src="{{ image.src | image_url: width: 510, height: 510 }}"
                  width="510"
                  height="510"
                  class="tw-w-[43px] tw-h-[43px] tw-object-contain tw-opacity-50"
                  alt="{{ image.alt }}"
                >
              </div>
            {% endfor %}
          </div>
        </div>
        <div
          id="view-nutrition-label-btn"
          class="
            tw-inline-flex
            tw-items-center
            tw-justify-center
            tw-font-bold
            tw-px-12
            tw-py-3
            tw-rounded-full
            tw-no-underline

            tw-bg-white
            hover:tw-bg-gray-200
            tw-text-black

            hover:tw-shadow-[0_0_0_0.5px_#000,2px_2px_0_#000]
            hover:tw-translate-x-1
            hover:tw-translate-y-1
            tw-shadow-[inset_0_0_0_0.5px_#000,4px_4px_0_#000]


            tw-transition-all
            tw-duration-300
            tw-ease-out

            tw-h-[46px]
            tw-w-full

            tw-text-[16px]

            tw-leading-[120%]
            tw-tracking-tighter

            tw-flex-nowrap
            tw-text-nowrap
            tw-cursor-pointer
          "
          data-sugar-free-image="{{ section.settings.selected-product.images[2].src | image_url: width: 1800 }}"
          data-low-sugar-image="{{ section.settings.selected-product.images[3].src | image_url: width: 1800 }}"
        >
          View Nutrition Label
        </div>
        {% render 'product-accordion', 
          blocks: section.blocks, 
          label: section.settings.accordion-label, 
          color: section.settings.accordion-color,
          show_mobile: false %}
      </div>
      {% comment %} product options here {% endcomment %}
      <div class="tw-flex tw-flex-col tw-max-w-[450px] tw-w-full">
        <product-form class="product-form tw-w-full">
