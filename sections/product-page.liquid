            <div class="tw-text-[#002613] tw-flex tw-flex-col tw-gap-[16px] tw-w-full tw-border tw-border-black tw-border-solid tw-border-r-[7px] tw-border-b-[7px] tw-px-[3%] tw-py-[13px] tw-rounded-[20px]">
