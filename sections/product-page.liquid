                    </label>
                  {%- endif -%}
                {%- endfor -%}
              </div>
              <div class="tw-flex tw-flex-col">
                <div class="tw-h-[25px] tw-flex tw-items-center">
                  <span class="tw-h-full tw-flex tw-items-center tw-justify-center">{% render 'icon-check' %}</span>
                  <p class="!tw-m-0">28 packs every 4 weeks (224 gummies)</p>
                </div>
                <div class="tw-h-[25px] tw-flex tw-items-center">
                  <span class="tw-h-full tw-flex tw-items-center tw-justify-center">{% render 'icon-check' %}</span>
                  <p class="!tw-m-0">FREE avg 2-day shipping today</p>
                </div>
                <div class="tw-h-[25px] tw-flex tw-items-center">
                  <span class="tw-h-full">{% render 'icon-check' %}</span>
                  <p class="!tw-m-0">Pause or cancel anytime</p>
                </div>
                <div class="tw-h-[25px] tw-flex tw-items-center">
                  <span class="tw-h-full">{% render 'icon-check' %}</span>
                  <p class="!tw-m-0">30-day money back guarantee</p>
                </div>
              </div>
              <button
                type="submit"
                class="
                  tw-inline-flex
                  tw-items-center
                  tw-justify-center
                  tw-font-bold
                  tw-px-12
                  tw-py-3
                  tw-rounded-full
                  tw-no-underline

                  hover:tw-shadow-[0_0_0_0.5px_#000,2px_2px_0_#000]
                  hover:tw-translate-x-1
                  hover:tw-translate-y-1
                  tw-shadow-[inset_0_0_0_0.5px_#000,4px_4px_0_#000]


                  tw-transition-all
                  tw-duration-300
                  tw-ease-out

                  tw-h-[46px]
                  tw-w-full

                  tw-text-[16px]

                  tw-leading-[120%]
                  tw-tracking-tighter

                  tw-flex-nowrap
                  tw-text-nowrap
                  tw-cursor-pointer
                  tw-relative
                "
                style="
                  background-color: {{ section.settings.start_now_button_bg_color }};
                  color: {{ section.settings.start_now_button_text_color }}
                "
                onmouseover="this.style.backgroundColor='{{ section.settings.start_now_button_hover_bg_color }}'"
