              {% endif %}
            </div>
          </form>
          {% assign one_time_purchase = section.settings.selected-product.options_with_values
            | where: "name", "Diet Type:"
            | first
          %}
        </product-form>
        {% for plan in one_time_purchase.values %}
          <product-form class="tw-w-full tw-max-w-[448px]" id="one_time_purchase_{{ plan | handleize }}">
          {% unless plan contains 'One Time' %}
