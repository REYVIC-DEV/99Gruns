<section>
  <div class="page-width tw-py-[41px] tw-px-[21px] tw-flex tw-flex-col tw-gap-[32px] md:tw-px-[32px] xl:tw-px-[72px]">

    <!-- Heading -->
    <div class="tw-w-full tw-flex tw-flex-col tw-gap-[12px]">
      <h3
        class="!tw-m-0 tw-text-center tw-text-[32px] xl:tw-text-[44px] tw-font-bold"
        style="color: {{ section.settings.heading_color }};"
      >
        {{ section.settings.heading }}
      </h3>
      <p class="!tw-m-0 tw-text-center tw-text-[16px] xl:tw-text-[20px]">
        {{ section.settings.subheading }}
      </p>
    </div>

    <!-- MOBILE IMAGE -->
    <div class="tw-w-full md:tw-hidden">
      <div class="tw-flex tw-justify-center">
        {% if section.settings.image %}
          {{ section.settings.image
            | image_url: width: 229, height: 300
            | image_tag: alt: section.settings.heading
          }}
        {% endif %}
      </div>
    </div>

    <!-- MOBILE SERVICES (2 COLUMNS) -->
    {% if section.blocks.size > 0 %}
      <div class="tw-grid tw-grid-cols-2 tw-gap-x-6 tw-gap-y-10 md:tw-hidden">
        {% for block in section.blocks %}

          <!-- Service 1 -->
          <div class="tw-flex tw-flex-col tw-items-center tw-text-center tw-gap-3">
            {% if block.settings.image_1 %}
              {{ block.settings.image_1 | image_url: width: 48 | image_tag }}
            {% endif %}
            <h4 class="!tw-m-0 tw-font-semibold tw-text-[16px]" style="color: {{ section.settings.service_text_color }};">
              {{ block.settings.title_1 }}
            </h4>
            <p class="!tw-m-0 tw-text-[13px] tw-leading-[140%] tw-text-gray-600">
              {{ block.settings.description_1 }}
            </p>
          </div>

          <!-- Service 2 -->
          <div class="tw-flex tw-flex-col tw-items-center tw-text-center tw-gap-3">
            {% if block.settings.image_2 %}
              {{ block.settings.image_2 | image_url: width: 48 | image_tag }}
            {% endif %}
            <h4 class="!tw-m-0 tw-font-semibold tw-text-[16px]" style="color: {{ section.settings.service_text_color }};">
              {{ block.settings.title_2 }}
            </h4>
            <p class="!tw-m-0 tw-text-[14px] tw-leading-[140%] tw-text-gray-600">
              {{ block.settings.description_2 }}
            </p>
          </div>

        {% endfor %}
      </div>
    {% endif %}

    <!-- DESKTOP / TABLET LAYOUT -->
    {% if section.blocks.size > 0 %}
      <div
        class="
          tw-hidden
          md:tw-grid
          tw-grid-cols-3
          tw-gap-x-12
          tw-items-center
        "
      >

        <!-- LEFT SERVICES -->
        <div class="tw-flex tw-flex-col tw-gap-12 xl:tw-pl-[128px]">
          {% for block in section.blocks %}
            <div class="tw-flex tw-flex-col tw-items-center tw-text-center tw-gap-3">
              {% if block.settings.image_1 %}
                {{ block.settings.image_1 | image_url: width: 48 | image_tag }}
              {% endif %}
              <h4 class="!tw-m-0 tw-font-semibold tw-text-[20px]" style="color: {{ section.settings.service_text_color }};">
                {{ block.settings.title_1 }}
              </h4>
              <p class="!tw-m-0 tw-text-[14px] xl:tw-text-[16px] tw-leading-[140%] tw-tracking-normal tw-text-gray-600">
                {{ block.settings.description_1 }}
              </p>
            </div>
          {% endfor %}
        </div>

        <!-- CENTER IMAGE -->
        <div class="tw-w-full xl:tw-hidden">
        <div class="tw-flex tw-justify-center">
            {% if section.settings.image %}
            {{ section.settings.image
                | image_url: width: 229, height: 300
                | image_tag: alt: section.settings.heading
            }}
            {% endif %}
        </div>
        </div>
        <div class="xl:tw-flex tw-justify-center tw-hidden xl:tw-w-[400px] xl:tw-h-[524px]">
          {% if section.settings.image %}
            {{ section.settings.image
              | image_url: width: 400, height: 524
              | image_tag: alt: section.settings.heading
            }}
          {% endif %}
        </div>

        <!-- RIGHT SERVICES -->
        <div class="tw-flex tw-flex-col tw-gap-12 xl:tw-pr-[128px]">
          {% for block in section.blocks %}
            <div class="tw-flex tw-flex-col tw-items-center tw-text-center tw-gap-3">
              {% if block.settings.image_2 %}
                {{ block.settings.image_2 | image_url: width: 48 | image_tag }}
              {% endif %}
              <h4 class="!tw-m-0 tw-font-semibold tw-text-[20px]" style="color: {{ section.settings.service_text_color }};">
                {{ block.settings.title_2 }}
              </h4>
              <p class="!tw-m-0 tw-text-[14px] xl:tw-text-[16px] tw-leading-[140%] tw-tracking-normal tw-text-gray-600">
                {{ block.settings.description_2 }}
              </p>
            </div>
          {% endfor %}
        </div>

      </div>
    {% endif %}

  </div>
</section>


{% schema %}
{
  "name": "Home Services",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Transform Your Health"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Over 35,000 research publications support the ingredients in Grüns."
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#007e40"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "color",
      "id": "service_text_color",
      "label": "Service Text Color",
      "default": "#007e40"
    }
  ],
  "blocks": [
    {
      "type": "service-container",
      "name": "Service Container",
      "settings": [
        {
          "type": "header",
          "content": "Service Item 1"
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Image 1"
        },
        {
          "type": "text",
          "id": "title_1",
          "label": "Title 1"
        },
        {
          "type": "textarea",
          "id": "description_1",
          "label": "Description 1"
        },
        {
          "type": "header",
          "content": "Service Item 2"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Image 2"
        },
        {
          "type": "text",
          "id": "title_2",
          "label": "Title 2"
        },
        {
          "type": "textarea",
          "id": "description_2",
          "label": "Description 2"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home Services"
    }
  ]
}
{% endschema %}
