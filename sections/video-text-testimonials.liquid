<section class="tw-w-full" style="background-color: {{ section.settings.bg_color }};" data-testimonial-tabs>
  <div class="page-width tw-p-[20px] tw-pt-[41px] tw-flex tw-flex-col tw-gap-[32px] md:tw-p-[5%] 2xl:tw-px-0">

    {%- comment -%} ===== HEADER (UNCHANGED) ===== {%- endcomment -%}
    <div class="tw-flex tw-flex-col tw-gap-[8px] tw-justify-center tw-w-full">
      {%- for block in section.blocks -%}
        {%- if block.type == 'star_reviews' -%}
          <div class="tw-w-full tw-flex tw-justify-center">
            {% render 'home-star-review',
              rating: block.settings.star_rating,
              star_color: block.settings.star_color,
              review_text_mobile: block.settings.review_text_mobile,
              review_text_desktop: block.settings.review_text_desktop,
              font_color: block.settings.review_font_color,
              strong_font_color: block.settings.strong_font_color
            %}
          </div>
        {%- endif -%}
      {%- endfor -%}

      <h3
        style="color: {{ section.settings.h3_color }};"
        class="!tw-m-0 tw-text-center tw-leading-[120%] tw-text-[32px] md:tw-text-[44px] tw-font-bold"
      >
        Join 1,000,000+ Others Filling Their Nutrition Gaps
      </h3>
    </div>

    {%- comment -%} ===== TABS/text part ===== {%- endcomment -%}
    <div
      class="
        tw-grid
        tw-grid-cols-2
        md:tw-grid-cols-3
        xl:tw-grid-cols-6
        tw-gap-[12px]
        tw-w-full
      "
    >
      {%- assign tab_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonial_tab' -%}
          <div
            class="
              tw-flex tw-justify-center tw-items-center
              tw-rounded-full
              !tw-border-2
              !tw-border-black
              tw-border-solid
              tw-py-[10px]
              tw-px-[18px]
              tw-font-semibold
              tw-text-black
              tw-transition
              tw-cursor-pointer

              hover:[&:not(.active)]:!tw-bg-green-tint
            "
            data-tab-button
            data-tab-index="{{ tab_index }}"
          >
            {{ block.settings.title }}
          </div>
          {%- assign tab_index = tab_index | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%} ===== REVIEWS ===== {%- endcomment -%}
    <div class="tw-max-w-[1200px] tw-mx-auto">

      {%- assign content_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'testimonial_tab' -%}
          <div
            class="
              testimonial-panel
              tw-hidden
              tw-grid
              tw-grid-cols-1
              xl:tw-grid-cols-3
              tw-gap-[24px]
              tw-max-w-[500px]
              xl:tw-max-w-full
            "
            data-tab-panel="{{ content_index }}"
          >

            <!-- Review 1 -->
            <div class="tw-flex tw-flex-col tw-gap-[12px] tw-items-center tw-text-center">
              {% render 'home-star-review', rating: 5, star_color: "#007e40" %}
              <p class="!tw-m-0 tw-font-bold tw-text-[20px] tw-tracking-tighter tw-leading-[120%]">{{ block.settings.review_1_title }}</p>
              {%- if block.settings.review_1_text != blank -%}
                <p class="!tw-m-0 tw-text-[16px] tw-leading-[160%] tw-tracking-tighter">{{ block.settings.review_1_text }}</p>
              {%- endif -%}
              <p class="!tw-m-0 tw-font-semibold">{{ block.settings.author_name_1 }}</p>
            </div>

            <!-- Review 2 -->
            <div class="tw-flex tw-flex-col tw-gap-[12px] tw-items-center tw-text-center">
              {% render 'home-star-review', rating: 5, star_color: "#007e40" %}
              <p class="!tw-m-0 tw-font-bold tw-text-[20px] tw-tracking-tighter tw-leading-[120%]">{{ block.settings.review_2_title }}</p>
              {%- if block.settings.review_2_text != blank -%}
                <p class="!tw-m-0 tw-text-[16px] tw-leading-[160%] tw-tracking-tighter">{{ block.settings.review_2_text }}</p>
              {%- endif -%}
              <p class="!tw-m-0 tw-font-semibold">{{ block.settings.author_name_2 }}</p>
            </div>

            <!-- Review 3 -->
            <div class="tw-flex tw-flex-col tw-gap-[12px] tw-items-center tw-text-center">
              {% render 'home-star-review', rating: 5, star_color: "#007e40" %}
              <p class="!tw-m-0 tw-font-bold tw-text-[20px] tw-tracking-tighter tw-leading-[120%]">{{ block.settings.review_3_title }}</p>
              {%- if block.settings.review_3_text != blank -%}
                <p class="!tw-m-0 tw-text-[16px] tw-leading-[160%] tw-tracking-tighter">{{ block.settings.review_3_text }}</p>
              {%- endif -%}
              <p class="!tw-m-0 tw-font-semibold">{{ block.settings.author_name_3 }}</p>
            </div>

          </div>

          {%- assign content_index = content_index | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}

    </div>

    {%- for block in section.blocks -%}
      {%- if block.type == 'video_slider' -%}
        <div class="tw-w-full">
          <!-- Slider -->
          <div class="swiper slider-vid-testimonial">
            <div class="swiper-wrapper !tw-w-[255px] !tw-h-[453px] md:!tw-w-[120px] md:!tw-h-[213px] lg:!tw-w-[166px] lg:!tw-h-[294px] xl:!tw-w-[240px] xl:!tw-h-[428px]">
              {%- for i in (1..5) -%}
                {%- assign video_key = 'video_' | append: i | append: '_url' -%}
                {%- assign video_url = block.settings[video_key] -%}
                {%- if video_url != blank -%}
                  <div class="swiper-slide tw-flex tw-items-center tw-justify-center">
                    <div class="tw-relative !tw-w-[255px] !tw-h-[453px] md:!tw-w-[120px] md:!tw-h-[213px] lg:!tw-w-[166px] lg:!tw-h-[294px] xl:!tw-w-[240px] xl:!tw-h-[428px] tw-rounded-[20px] tw-overflow-hidden">
                      <iframe
                        src="{{ video_url }}"
                        class="tw-absolute tw-inset-0 tw-w-full tw-h-full"
                        frameborder="0"
                        allow="autoplay; fullscreen; picture-in-picture"
                        allowfullscreen>
                      </iframe>
                    </div>
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>

          <!-- Controls BELOW slider -->
          <div class="tw-mt-[16px] tw-flex tw-items-center tw-justify-center tw-gap-[20px] md:tw-hidden">
            <div class="swiper-button-prev-tv tw-flex tw-items-center">
              {% render 'icon-arrow', direction: 'left', color: "#00582d", size: 32 %}
            </div>

            <div class="swiper-pagination-tv !tw-w-auto !tw-justify-center"></div>

            <div class="swiper-button-next-tv tw-flex tw-items-center">
              {% render 'icon-arrow', direction: 'right', color: "#00582d", size: 32 %}
            </div>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
    <p class="tw-text-[10px] tw-text-center">Testimonials featured in videos or other promotional materials may include individuals who have received compensation, free product, or other incentives.</p>
  </div>
</section>

<style>
.swiper-pagination-tv {
  display: flex;
  align-items: center;
  gap: 8px;
}

.swiper-pagination-tv .swiper-pagination-bullet {
  width: 8px;
  height: 8px;
  background: #cfd8d3; /* light gray/green */
  opacity: 1;
}

.swiper-pagination-tv .swiper-pagination-bullet-active {
  background: #00582d; /* active green */
}

</style>

<script src="{{ 'video-testimonial-slider.js' | asset_url }}" defer="defer"></script>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector('[data-testimonial-tabs]');
    if (!section) return;

    const buttons = section.querySelectorAll('[data-tab-button]');
    const panels = section.querySelectorAll('.testimonial-panel');

    function activateTab(index) {
      buttons.forEach(btn => {
        btn.classList.toggle('active', btn.dataset.tabIndex == index);
        btn.classList.toggle('tw-bg-green', btn.dataset.tabIndex == index);
        btn.classList.toggle('tw-text-white', btn.dataset.tabIndex == index);
      });

      panels.forEach(panel => {
        panel.classList.toggle('tw-hidden', panel.dataset.tabPanel != index);
      });
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        activateTab(btn.dataset.tabIndex);
      });
    });

    // Activate first tab by default
    activateTab(0);
  });
</script>


