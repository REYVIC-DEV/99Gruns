
<style>

    .recommend-swiper-pagination .swiper-pagination-bullet{
        background: transparent;
        opacity: 1;

        background-color: #0000004D !important;
        height: 12px !important;
        width: 12px !important;
        border: 1px solid #000000 !important;
    }
    .recommend-swiper-pagination .swiper-pagination-bullet-active{
        background-color: #000000 !important;
        height: 12px !important;
        width: 12px !important;
    }
</style>
<script src="{{ 'recommend-slider.js' | asset_url }}" defer></script>
<section class="tw-w-full tw-bg-[#fff2cb]">
    <div class="page-width tw-w-full tw-flex tw-flex-col tw-py-[40px] tw-gap-[24px]">
        <div class=" tw-flex tw-justify-center tw-text-center tw-max-w-[382px] md:tw-max-w-full">
            <h2 class="!tw-m-0 tw-text-[32px] md:tw-text-[44px] tw-leading-[110%] tw-font-bold">{{ section.settings.section-title }}</h2>
        </div>
        <!-- Slider main container -->
        <div class="swiper recommend-slider tw-w-full">
            <!-- Additional required wrapper -->
            <div class="swiper-wrapper">
                {% for i in (1..3) %}
                    {% for block in section.blocks %}
                        <div class="swiper-slide tw-w-[300px] tw-h-[410px] tw-overflow-hidden tw-rounded-[12px] tw-border tw-border-black tw-border-solid !tw-border-r-4 !tw-border-b-4 tw-bg-white">
                            <img src="{{ block.settings.slide-img | image_url: width: 300}}" alt="{{ block.settings.slide-title }}" loading="lazy" width="300" height="198">
                            <div class="tw-px-[12px]">
                                <h3 class="!tw-m-0 tw-font-semibold tw-text-[18px]">{{ block.settings.slide-title }}</h3>
                                <p class="!tw-m-0 tw-text-[14px]">{{ block.settings.slide-description }}</p>
                            </div>
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>

        </div>
        <div class="tw-flex tw-justify-center tw-items-center tw-gap-[24px]">
            <div class="recommend-swiper-button-prev tw-cursor-pointer tw-p-[8px] tw-flex tw-items-center tw-border tw-border-black tw-border-solid tw-border-r-4 tw-border-b-4 tw-rounded-full tw-h-[56px] tw-w-[56px] tw-bg-[#ffcc2e]">
                {% render 'icon-arrow', direction: 'left', color: '#000000', size: section.settings.arrow_size %}
            </div>
            <div class="recommend-swiper-pagination !tw-w-auto"></div>
            <div class="recommend-swiper-button-next tw-cursor-pointer tw-p-[8px] tw-flex tw-items-center tw-border tw-border-black tw-border-solid tw-border-r-4 tw-border-b-4 tw-rounded-full tw-h-[56px] tw-w-[56px] tw-bg-[#ffcc2e]">
                {% render 'icon-arrow', direction: 'right', color: '#000000', size: section.settings.arrow_size %}
            </div>
        </div>
    </div>
</section>
{% schema %}
    {
        "name": "Recommendations Slider",
        "settings": [
            {
                "type": "text",
                "id": "section-title",
                "label": "Section Title",
                "default": "Recommended by Parents & Pediatricians"
            },
        ],
        "blocks": [
            {
                "type": "slide",
                "name": "Slide",
                "settings": [
                    {
                        "type": "image_picker",
                        "id": "slide-img",
                        "label": "Image"
                    },
                    {
                        "type": "text",
                        "id": "slide-title",
                        "label": "Title",
                        "default": "Title",
                    },
                    {
                        "type": "text",
                        "id": "slide-description",
                        "label": "Description",
                        "default": "Description",
                    },
                ]
            }
        ],
        "presets": [
            {
                "name": "Recommendations Slider",
                "category": "Slider"
            }
        ]
    }
{% endschema %}