<style>
  	.section-{{ section.id }}-padding {
		padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
		padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
	}

	@media screen and (min-width: 750px) {
		.section-{{ section.id }}-padding {
			padding-top: {{ section.settings.padding_top }}px;
			padding-bottom: {{ section.settings.padding_bottom }}px;
		}
	}
</style>

<section
  id="section-{{ section.id }}"
  class="tw-flex tw-flex-col md:tw-flex-row tw-justify-between tw-p-[15px] tw-pb-[30px] md:tw-p-[38px] xl:tw-px-0 section-{{ section.id }}-padding"
  style="background-color: {{ section.settings.bg_color }};"
>

  <div class="page-width !tw-p-0 tw-flex tw-flex-col tw-gap-[16px] md:tw-gap-[12px] xl:tw-flex-row xl:tw-justify-between xl:tw-w-full xl:!tw-px-[72px]">

    <div class="tw-flex tw-flex-col tw-items-center tw-w-full tw-text-center md:tw-flex-row xl:tw-flex-col xl:tw-items-start xl:tw-w-[513px]">
        <h2
          class="tw-font-bold tw-mb-4 !tw-m-0 md:tw-text-left md:tw-w-[50%] xl:tw-w-auto"
          style="
            color: {{ section.settings.heading_color }};
            font-size: {{ section.settings.heading_font_size_mobile }}px;
          "
        >
          {{ section.settings.heading }}
        </h2>
        <p
          class="tw-font-mediumbold tw-text-gray-700 !tw-m-0 md:tw-text-left md:tw-w-[50%] xl:tw-w-full"
          style="
            color: {{ section.settings.text_color }};
            font-size: {{ section.settings.text_font_size_mobile }}px; 
          "
        >
          {{ section.settings.text }}
        </p>
      </div>
    
    <div class="tw-w-full tw-relative tw-overflow-hidden xl:tw-w-[738px]">
    
      <!-- Mobile Image: visible on small screens only -->
      {% if section.settings.image_mobile %}
        <img
          src="{{ section.settings.image_mobile | image_url: width: 362 }}"
          alt="{{ section.settings.image_alt }}"
          class="tw-block md:tw-hidden tw-w-full tw-h-full"
          style="object-fit: cover;"
          width="362"
          height="auto"
        >
      {% endif %}
    
      <!-- Desktop Image: visible on medium+ screens only -->
      {% if section.settings.image %}
        <img
          src="{{ section.settings.image | image_url: width: 738 }}"
          alt="{{ section.settings.image_alt }}"
          class="tw-hidden md:tw-block tw-h-full md:tw-w-full xl:tw-w-auto"
          style="object-fit: cover;"
          width="738"
          height="auto"
        >
      {% endif %}
    
    </div>
  </div>

  <!-- Left Column: Text -->



  <!-- Desktop font sizes -->
 <style>
  /* DESKTOP padding */
  #section-{{ section.id }}.section-padding {
    padding: 100px;
  }

  /* MOBILE padding */
  @media (max-width: 767px) {
    #section-{{ section.id }}.section-padding {
      padding: 32px 20px;
    }
  }

  /* Desktop font sizes */
  @media (min-width: 768px) {
    #section-{{ section.id }} h2 {
      font-size: {{ section.settings.heading_font_size }}px !important;
    }
    #section-{{ section.id }} p {
      font-size: {{ section.settings.text_font_size }}px !important;
    }
  }
</style>


</section>

{% schema %}
{
  "name": "Section 7",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Headline",
      "default": "Your headline here"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Headline Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Headline Font Size Desktop (px)",
      "min": 16,
      "max": 72,
      "step": 1,
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "label": "Headline Font Size Mobile (px)",
      "min": 12,
      "max": 48,
      "step": 1,
      "default": 24
    },
        {
			"type": "range",
			"id": "padding_top",
			"min": 0,
			"max": 100,
			"step": 4,
			"unit": "px",
			"label": "Padding top",
			"default": 64
		},
		{
			"type": "range",
			"id": "padding_bottom",
			"min": 0,
			"max": 100,
			"step": 4,
			"unit": "px",
			"label": "Padding bottom",
			"default": 64
		},
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Your description text goes here."
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#555555"
    },
    {
      "type": "range",
      "id": "text_font_size",
      "label": "Text Font Size Desktop (px)",
      "min": 12,
      "max": 36,
      "step": 1,
      "default": 16
    },
    {
      "type": "range",
      "id": "text_font_size_mobile",
      "label": "Text Font Size Mobile (px)",
      "min": 10,
      "max": 24,
      "step": 1,
      "default": 14
    },
    {
  "type": "image_picker",
  "id": "image",
  "label": "Desktop Image"
},
{
  "type": "image_picker",
  "id": "image_mobile",
  "label": "Mobile Image"
},

    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "Image description"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Horizontal Text with Customizable Image"
    }
  ]
}
{% endschema %}
